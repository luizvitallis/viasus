# ============================================================
#  ViaSus — variáveis de ambiente
# ============================================================
#  Copie este arquivo para `.env.local` e preencha com os
#  valores reais. NUNCA commit `.env.local`.
#
#  Onde encontrar (Supabase): Dashboard > Settings > API
# ============================================================

# URL do projeto Supabase (sem caminho)
# ex.: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública (anon) — pode ir ao browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service_role — JAMAIS no cliente.
# Usada apenas em route handlers e server actions privilegiadas.
SUPABASE_SERVICE_ROLE_KEY=
