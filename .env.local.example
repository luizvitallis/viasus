# ============================================================
#  ViaSus — variáveis de ambiente
# ============================================================
#  Copie este arquivo para `.env.local` e preencha com os
#  valores reais. NUNCA commit `.env.local`.
#
#  Onde encontrar (Supabase): Dashboard > Settings > API
#
#  Em 2026-04-29 a Supabase migrou de anon/service_role para
#  publishable/secret. Os nomes das env vars refletem o novo padrão.
# ============================================================

# URL do projeto Supabase (sem caminho)
# ex.: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chave publishable (sb_publishable_…) — pode ir ao browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Chave secret (sb_secret_…) — JAMAIS no cliente.
# Usada apenas em server actions, route handlers privilegiados e
# scripts de seed/manutenção.
SUPABASE_SECRET_KEY=
